<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--__________ United States Secret Service Recipes __________-->

    <!--_____ Secret Service Underarmor _____-->

    <!-- Secret Service Underarmor -->

    <RecipeDef>
        <defName>FCP_Recipe_Make_USA_Secret_Service_Underarmor</defName>
        <label>make Secret Service Underarmor</label>
        <description>Craft Secret Service Underarmor using classified schematics. Requires positive relations with the United States.</description>
        <jobString>Making Secret Service Underarmor.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Tailor</effectWorking>
        <soundWorking>Recipe_Tailor</soundWorking>
        <workAmount>12000</workAmount>
        <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Cloth</li>
                    </thingDefs>
                </filter>
                <count>60</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>30</count>
            </li>
        </ingredients>
        <products>
            <FCP_Apparel_USA_Secret_Service_Underarmor>1</FCP_Apparel_USA_Secret_Service_Underarmor>
        </products>
        <skillRequirements>
            <Crafting>6</Crafting>
        </skillRequirements>
        <recipeUsers>
            <li>FCP_Production_Tailoring_Workbench</li>
        </recipeUsers>
        <researchPrerequisite>FCP_Research_USA_Infantry_Variations</researchPrerequisite>
        <modExtensions>
            <li Class="FCP.Factions.RecipeExtension_FactionGoodwillCheck">
                <requireFaction>FCP_Faction_USA</requireFaction>
                <minimumGoodwill>70</minimumGoodwill>
                <uncraftableIfFactionDefeated>true</uncraftableIfFactionDefeated>
            </li>
        </modExtensions>
    </RecipeDef>

