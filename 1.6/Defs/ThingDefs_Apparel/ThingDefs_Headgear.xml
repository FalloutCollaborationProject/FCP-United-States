        <recipeMaker>
            <researchPrerequisite>FCP_Research_MilitaryUniforms</researchPrerequisite>
        </recipeMaker>
        <graphicData>
            <texPath>Things/Apparel/US_Army_Generals_Outfit/FCP_US_Army_General_Hat</texPath>
        </graphicData>
