<Defs>

    <!--__________ United States of America __________-->

    <!--_____ US Headgear _____-->

    <!--___ Military ___-->

    <!--__ US Combat Armor Helmet __-->

    <!--_ Standard _-->

    <!-- US Army Combat Helmet -->

    <ThingDef ParentName="FCP_Apparel_Combat_Helmet_Base">
        <defName>FCP_Apparel_USA_Army_Combat_Helmet</defName>
        <label>US Army Combat Helmet</label>
        <description>The standard-issue US Army Combat Helmet of 2077, designed to complement the advanced composite plating and modular features of the armor. Widely deployed alongside its armor counterpart, it provides robust protection against ballistic and energy threats while maintaining comfort and tactical functionality. Integrated with environmental seals and communication interfaces, this helmet exemplifies the pinnacle of military headgear technology in the United States.</description>
        <graphicData>
            <texPath>Things/Apparel/US_Army_Combat_Armor/FCP_US_Army_Combat_Helmet</texPath>
        </graphicData>
        <recipeMaker>
            <researchPrerequisite>FCP_Research_USA_Standard_Infantry_Gear</researchPrerequisite>
        </recipeMaker>
        <costList>
            <Steel>40</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_Army_Combat_Armor/FCP_US_Army_Combat_Helmet</wornGraphicPath>
            <tags>
                <li>FCP_USA_Army_Armor</li>
            </tags>
            <defaultOutfitTags inherit="false">
                <li>FCP_USA_Combat_Armor</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

    <!--_ Winterized _-->

    <!-- Winterized US Army Combat Helmet -->

    <ThingDef ParentName="FCP_Apparel_Combat_Helmet_Base">
        <defName>FCP_Apparel_USA_Winterized_Army_Combat_Helmet</defName>
        <label>Winterized US Army Combat Helmet</label>
        <description>The winterized variant of the US Army Combat Helmet, issued in 2077 for operations in extreme cold environments. Enhanced with advanced thermal insulation, weatherproofing, and an integrated facial protection system, it maintains the robust protection and sophisticated features of the standard model while ensuring comfort and operational effectiveness in harsh winter conditions. The built-in thermal faceguard offers superior coverage against wind and frostbite, while integrated environmental seals and communication interfaces remain standard, making this helmet essential for cold-weather deployments.</description>
        <graphicData>
            <texPath>Things/Apparel/US_Army_Winterized_Combat_Armor/FCP_Winterized_Combat_Helmet</texPath>
        </graphicData>
        <recipeMaker>
            <researchPrerequisite>FCP_Research_USA_Infantry_Variations</researchPrerequisite>
        </recipeMaker>
        <costList>
            <Steel>40</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
            <Cloth>10</Cloth>
        </costList>
        <statBases>
            <Insulation_Cold>4</Insulation_Cold>
            <Insulation_Heat>-0.5</Insulation_Heat>
        </statBases>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_Army_Winterized_Combat_Armor/FCP_Winterized_Combat_Helmet</wornGraphicPath>
            <tags>
                <li>FCP_USA_Army_Armor</li>
            </tags>
            <defaultOutfitTags inherit="false">
                <li>FCP_USA_Combat_Armor</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
            <li Class="FCP.Core.CompProperties_TemperatureApparelPreference">
              <forceBelowTempC>4</forceBelowTempC>
              <avoidAboveTempC>5</avoidAboveTempC>
            </li>
        </comps>
    </ThingDef>

    <!--__ US Marine Combat Helmet __-->

    <!--_ Standard _-->

    <!-- US Marine Combat Helmet -->

    <ThingDef ParentName="FCP_Apparel_Combat_Helmet_Base">
        <defName>FCP_Apparel_USA_Marine_Combat_Helmet</defName>
        <label>US Marine Combat Helmet</label>
        <description>The standard-issue US Marine Corps Combat Helmet of 2077, engineered specifically for the elite Marine Corps with enhanced ballistic protection and amphibious operation capabilities. Features advanced composite materials, integrated communication systems, environmental seals, and a built-in atmospheric filtration system that provides protection against chemical agents, toxic gases, and environmental hazards. This helmet represents the pinnacle of Marine Corps tactical headgear technology.</description>
        <graphicData>
            <texPath>Things/Apparel/US_Marine_Armor/FCP_US_Marine_Helmet</texPath>
        </graphicData>
        <costList>
            <Steel>40</Steel>
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <statBases>
            <MaxHitPoints>180</MaxHitPoints>
            <MarketValue>650</MarketValue>
            <Mass>2.5</Mass>
            <ArmorRating_Sharp>1.80</ArmorRating_Sharp>
            <ArmorRating_Blunt>1.60</ArmorRating_Blunt>
            <ArmorRating_Heat>1.20</ArmorRating_Heat>
            <Insulation_Cold>4</Insulation_Cold>
            <Insulation_Heat>2</Insulation_Heat>
            <EquipDelay>1.0</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <ToxicResistance>0.75</ToxicResistance>
        </equippedStatOffsets>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_Marine_Armor/FCP_US_Marine_Helmet</wornGraphicPath>
            <tags>
                <li>FCP_USA_Marine_Armor</li>
            </tags>
            <defaultOutfitTags>
                <li>FCP_USA_Marine_Armor</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
    </ThingDef>

    <!--__ US Marine Diving Helmet __-->

    <!--_ Standard _-->

    <!-- US Marine Diving Helmet -->

    <ThingDef ParentName="ApparelBase">
        <defName>FCP_Apparel_USA_Marine_Diving_Helmet</defName>
        <label>US Marine Diving Helmet</label>
        <description>A specialized diving helmet used by United States Marine Corps combat divers and underwater demolition teams. Features an integrated breathing system, reinforced visor, and communication equipment designed for underwater operations. Provides excellent protection against environmental hazards while maintaining clear vision and communication capabilities during amphibious assaults.</description>
        <smeltable>false</smeltable>
        <thingCategories>
            <li>Apparel</li>
        </thingCategories>
        <graphicData>
            <texPath>Things/Apparel/US_Marine_Wetsuit/FCP_Marine_Wetsuit_Helmet</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <techLevel>Industrial</techLevel>
        <statBases>
            <MaxHitPoints>80</MaxHitPoints>
            <MarketValue>180</MarketValue>
            <Mass>1.8</Mass>
            <ArmorRating_Sharp>0.45</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.55</ArmorRating_Blunt>
            <ArmorRating_Heat>0.35</ArmorRating_Heat>
            <Insulation_Cold>3</Insulation_Cold>
            <Insulation_Heat>2</Insulation_Heat>
            <EquipDelay>1.0</EquipDelay>
        </statBases>
        <apparel>
            <bodyPartGroups>
                <li>UpperHead</li>
                <li>FullHead</li>
            </bodyPartGroups>
            <wornGraphicPath>Things/Apparel/US_Marine_Wetsuit/FCP_Marine_Wetsuit_Helmet</wornGraphicPath>
            <layers>
                <li>Overhead</li>
            </layers>
            <tags>
                <li>FCP_USA_Marine_Wetsuit</li>
            </tags>
            <defaultOutfitTags>
                <li>FCP_USA_Marine_Wetsuit</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
        <tradeTags>
            <li>FCP_Trade_Tag_USA_Apparel</li>
        </tradeTags>
    </ThingDef>

    <!--__ US Officers Cap __-->

