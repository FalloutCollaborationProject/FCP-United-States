    <!--__ T-65 Power Armor __-->

    <!-- T-65 Secret Service Power Armor -->

    <ThingDef ParentName="FCP_Apparel_Power_Armor_Base" MayRequire="Rick.FCP.PowerArmor">
        <defName>FCP_Apparel_USA_T65_Power_Armor</defName>
        <label>T-65 Secret Service Power Armor</label>
        <description>The pinnacle of pre-war American power armor technology, the T-65 was developed exclusively for elite Secret Service operatives assigned to the most critical national security operations. Incorporating cutting-edge materials science and engineering far beyond standard military issue, this armor provides unmatched protection and strength enhancement. Its distinctive profile is instantly recognizable to those familiar with the inner workings of the United States government.</description>
        <graphicData>
            <texPath>Things/Apparel/US_T65_Power_Armor/FCP_US_T65_Power_Armor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1</drawSize>
        </graphicData>
        <statBases>
            <MaxHitPoints>450</MaxHitPoints>
            <WorkToMake>45000</WorkToMake>
            <Mass>22.0</Mass>
            <MarketValue>5500</MarketValue>
            <ArmorRating_Sharp>3.20</ArmorRating_Sharp>
            <ArmorRating_Blunt>3.00</ArmorRating_Blunt>
            <ArmorRating_Heat>2.60</ArmorRating_Heat>
            <Insulation_Cold>40</Insulation_Cold>
            <Insulation_Heat>28</Insulation_Heat>
            <EquipDelay>4.5</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <ToxicEnvironmentResistance>1.0</ToxicEnvironmentResistance>
            <CarryingCapacity>30</CarryingCapacity>
            <MoveSpeed>-0.2</MoveSpeed>
        </equippedStatOffsets>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_T65_Power_Armor/FCP_US_T65_Power_Armor</wornGraphicPath>
            <tags>
                <li>FCP_USA_Secret_Service_Heavy</li>
                <li>FCP_Power_Armor</li>
            </tags>
            <defaultOutfitTags inherit="false">
                <li>FCP_USA_Secret_Service_Heavy</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
            <li Class="FCP.Core.PowerArmor.CompProperties_RepairableAtStation">
