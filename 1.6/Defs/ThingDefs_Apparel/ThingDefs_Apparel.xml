    <!--_ Standard _-->

    <!-- US Combat Armor -->

    <ThingDef ParentName="FCP_Apparel_Combat_Armor_Base">
        <defName>FCP_Apparel_USA_Army_Combat_Armor</defName>
        <description>The standard-issue US Army Combat Armor of 2077, featuring advanced composite plating and modular design. Widely deployed across conflict zones, it offers robust protection against ballistic and energy threats while maintaining mobility. Integrated with environmental seals and tactical interfaces, this armor represents the pinnacle of military technology in the United States.</description>
        <label>US Army Combat Armor</label>
        <recipeMaker>
            <researchPrerequisite>FCP_Research_USA_Standard_Infantry_Gear</researchPrerequisite>
        </recipeMaker>
        <graphicData>
            <texPath>Things/Apparel/US_Army_Combat_Armor/FCP_US_Army_Combat_Armor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_Army_Combat_Armor/FCP_US_Army_Combat_Armor</wornGraphicPath>
            <tags>
                <li>FCP_USA_Army_Armor</li>
            </tags>
            <defaultOutfitTags inherit="false">
                <li>FCP_USA_Combat_Armor</li>
            </defaultOutfitTags>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
        </comps>
        <tradeTags>
            <li>FCP_Trade_Tag_USA_Apparel</li>
        </tradeTags>
    </ThingDef>

    <!--_ Winterized _-->

    <!-- Winterized US Combat Armor -->

    <ThingDef ParentName="FCP_Apparel_Combat_Armor_Base">
        <defName>FCP_Apparel_USA_Winterized_Army_Combat_Armor</defName>
        <description>The winterized variant of the US Army Combat Armor of 2077, featuring advanced composite plating, modular design, and enhanced insulation for extreme cold. Outfitted with weatherproof materials and environmental seals, it offers robust protection against ballistic and energy threats while ensuring soldier mobility and warmth in harsh winter conditions.</description>
        <label>Winterized US Army Combat Armor</label>
        <recipeMaker>
            <researchPrerequisite>FCP_Research_USA_Infantry_Variations</researchPrerequisite>
        </recipeMaker>
        <statBases>
            <Insulation_Cold>5.0</Insulation_Cold>
            <Insulation_Heat>-0.8</Insulation_Heat>
        </statBases>
        <graphicData>
            <texPath>Things/Apparel/US_Army_Winterized_Combat_Armor/FCP_Winterized_Combat_Armor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <apparel>
            <wornGraphicPath>Things/Apparel/US_Army_Winterized_Combat_Armor/FCP_Winterized_Combat_Armor</wornGraphicPath>
            <tags>
                <li>FCP_USA_Army_Armor</li>
            </tags>
            <defaultOutfitTags inherit="false">
                <li>FCP_USA_Combat_Armor</li>
            </defaultOutfitTags>
            <layers>
                <li>OnSkin</li>
                <li>Middle</li>
                <li>Shell</li>
            </layers>
        </apparel>
        <comps>
            <li Class="FCP.Core.CompProperties_LabelColored">
                <rarity>Rare</rarity>
            </li>
            <li Class="FCP.Core.CompProperties_TemperatureApparelPreference">
                <forceBelowTempC>4</forceBelowTempC>
                <avoidAboveTempC>5</avoidAboveTempC>
            </li>
        </comps>
        <tradeTags>
            <li>FCP_Trade_Tag_USA_Apparel</li>
        </tradeTags>
    </ThingDef>

